      {
        "id": "d392a26e-f681-479e-a75a-ddfd4a32989f",
        "parentCode": "SIMULATOR_HEALTH-1775422916457",
        "parentCodeOrigin": "DEV-01",
        "code": "SCRIPT-1775422952313",
        "type": "SCRIPT",
        "description": "simulator_health",
        "content": "\n    <script>\n        let patients = {};\n        let intervals = {};\n        let currentContentNodeCode = null;\n\n        // Seuils médicaux\n        const thresholds = {\n            heart_rate: { min: 60, max: 100, warningMin: 50, warningMax: 120, criticalMin: 40, criticalMax: 140 },\n            systolic: { min: 90, max: 120, warningMin: 80, warningMax: 140, criticalMin: 70, criticalMax: 160 },\n            diastolic: { min: 60, max: 80, warningMin: 50, warningMax: 90, criticalMin: 40, criticalMax: 100 },\n            temperature: { min: 36.1, max: 37.2, warningMin: 35.5, warningMax: 38.5, criticalMin: 35, criticalMax: 39.5 },\n            oxygen: { min: 95, max: 100, warningMin: 90, warningMax: 100, criticalMin: 85, criticalMax: 100 }\n        };\n\n        // Générer une clé unique pour un patient\n        function generateDataKey(patientId) {\n            return `health_${patientId}`;\n        }\n\n        // Vérifier le contentNodeCode\n        function getContentNodeCode() {\n            const code = document.getElementById('contentNodeCode').value.trim();\n            if (!code) {\n                addLog(\"❌ Veuillez entrer un Content Node Code\");\n                return null;\n            }\n            return code;\n        }\n\n        // Évaluer le niveau d'alerte\n        function evaluateAlertLevel(data) {\n            let level = \"normal\";\n            \n            // Rythme cardiaque\n            if (data.heart_rate <= thresholds.heart_rate.criticalMin || data.heart_rate >= thresholds.heart_rate.criticalMax) {\n                level = \"critical\";\n            } else if (data.heart_rate <= thresholds.heart_rate.warningMin || data.heart_rate >= thresholds.heart_rate.warningMax) {\n                if (level !== \"critical\") level = \"warning\";\n            }\n            \n            // Tension systolique\n            if (data.blood_pressure_systolic <= thresholds.systolic.criticalMin || data.blood_pressure_systolic >= thresholds.systolic.criticalMax) {\n                level = \"critical\";\n            } else if (data.blood_pressure_systolic <= thresholds.systolic.warningMin || data.blood_pressure_systolic >= thresholds.systolic.warningMax) {\n                if (level !== \"critical\") level = \"warning\";\n            }\n            \n            // Tension diastolique\n            if (data.blood_pressure_diastolic <= thresholds.diastolic.criticalMin || data.blood_pressure_diastolic >= thresholds.diastolic.criticalMax) {\n                level = \"critical\";\n            } else if (data.blood_pressure_diastolic <= thresholds.diastolic.warningMin || data.blood_pressure_diastolic >= thresholds.diastolic.warningMax) {\n                if (level !== \"critical\") level = \"warning\";\n            }\n            \n            // Température\n            if (data.temperature <= thresholds.temperature.criticalMin || data.temperature >= thresholds.temperature.criticalMax) {\n                level = \"critical\";\n            } else if (data.temperature <= thresholds.temperature.warningMin || data.temperature >= thresholds.temperature.warningMax) {\n                if (level !== \"critical\") level = \"warning\";\n            }\n            \n            // Oxygène\n            if (data.oxygen_saturation <= thresholds.oxygen.criticalMin) {\n                level = \"critical\";\n            } else if (data.oxygen_saturation <= thresholds.oxygen.warningMin) {\n                if (level !== \"critical\") level = \"warning\";\n            }\n            \n            return level;\n        }\n\n        // Générer des données vitales aléatoires mais réalistes\n        function generateHealthData(patientId) {\n            const baseData = patients[patientId]?.lastData || {\n                heart_rate: 75,\n                systolic: 110,\n                diastolic: 70,\n                temperature: 36.8,\n                oxygen: 97\n            };\n            \n            // Variation progressive\n            return {\n                heart_rate: Math.max(40, Math.min(150, Math.round(baseData.heart_rate + (Math.random() - 0.5) * 4))),\n                blood_pressure_systolic: Math.max(70, Math.min(180, Math.round(baseData.systolic + (Math.random() - 0.5) * 3))),\n                blood_pressure_diastolic: Math.max(50, Math.min(110, Math.round(baseData.diastolic + (Math.random() - 0.5) * 2))),\n                temperature: Math.max(35, Math.min(40, +(baseData.temperature + (Math.random() - 0.5) * 0.2).toFixed(1))),\n                oxygen_saturation: Math.max(70, Math.min(100, Math.round(baseData.oxygen + (Math.random() - 0.5) * 1.5)))\n            };\n        }\n\n        // Créer ou mettre à jour les données dans Nodify\n        async function sendHealthData(patientId) {\n            const contentNodeCode = getContentNodeCode();\n            if (!contentNodeCode) return;\n            \n            const patient = patients[patientId];\n            if (!patient) return;\n            \n            const healthData = generateHealthData(patientId);\n            const alertLevel = evaluateAlertLevel(healthData);\n            \n            // Sauvegarder pour la prochaine variation\n            patients[patientId].lastData = healthData;\n            \n            const now = Date.now();\n            const dataKey = generateDataKey(patientId);\n            \n            const healthPayload = {\n                device_id: patientId,\n                patient_name: patient.name,\n                heart_rate: healthData.heart_rate,\n                blood_pressure_systolic: healthData.blood_pressure_systolic,\n                blood_pressure_diastolic: healthData.blood_pressure_diastolic,\n                temperature: healthData.temperature,\n                oxygen_saturation: healthData.oxygen_saturation,\n                alert_level: alertLevel,\n                timestamp: new Date().toISOString(),\n                timestamp_ms: now\n            };\n            \n            const payload = {\n                key: dataKey,\n                name: `Données santé - ${patient.name} (${patientId})`,\n                dataType: \"json\",\n                value: JSON.stringify(healthPayload),\n                creationDate: now,\n                modificationDate: now,\n                contentNodeCode: contentNodeCode,\n                user: patient.name\n            };\n            \n            try {\n                let response;\n                \n                if (patients[patientId].uuid) {\n                    // Mise à jour\n                    payload.id = patients[patientId].uuid;\n                    response = await fetch(`/datas/id/${patients[patientId].uuid}`, {\n                        method: 'PUT',\n                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },\n                        body: JSON.stringify(payload)\n                    });\n                } else {\n                    // Création\n                    response = await fetch(`/datas/`, {\n                        method: 'POST',\n                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },\n                        body: JSON.stringify(payload)\n                    });\n                }\n                \n                if (response.ok && !patients[patientId].uuid) {\n                    const result = await response.json();\n                    patients[patientId].uuid = result.id;\n                }\n                \n                updatePatientUI(patientId, healthData, alertLevel);\n                \n            } catch (error) {\n                addLog(`❌ Erreur ${patientId}: ${error.message}`);\n            }\n        }\n\n        // Mettre à jour l'interface d'un patient\n        function updatePatientUI(patientId, data, alertLevel) {\n            const container = document.getElementById(`patient-${patientId}`);\n            if (!container) return;\n            \n            const alertClass = alertLevel === 'critical' ? 'alert-critical' : (alertLevel === 'warning' ? 'alert-warning' : 'alert-normal');\n            const alertText = alertLevel === 'critical' ? '🚨 CRITIQUE' : (alertLevel === 'warning' ? '⚠️ ATTENTION' : '✅ NORMAL');\n            \n            const alertBadge = container.querySelector('.alert-badge');\n            if (alertBadge) {\n                alertBadge.innerHTML = alertText;\n                alertBadge.className = `alert-badge ${alertClass}`;\n            }\n            \n            const hrSpan = container.querySelector('.heart-rate-value');\n            if (hrSpan) hrSpan.innerHTML = data.heart_rate;\n            \n            const sysSpan = container.querySelector('.systolic-value');\n            if (sysSpan) sysSpan.innerHTML = data.blood_pressure_systolic;\n            \n            const diaSpan = container.querySelector('.diastolic-value');\n            if (diaSpan) diaSpan.innerHTML = data.blood_pressure_diastolic;\n            \n            const tempSpan = container.querySelector('.temperature-value');\n            if (tempSpan) tempSpan.innerHTML = data.temperature;\n            \n            const oxSpan = container.querySelector('.oxygen-value');\n            if (oxSpan) oxSpan.innerHTML = data.oxygen_saturation;\n            \n            // Changer les couleurs\n            const vitalValues = container.querySelectorAll('.vital-value');\n            vitalValues.forEach(el => {\n                el.classList.remove('status-normal', 'status-warning', 'status-critical');\n                if (alertLevel === 'critical') el.classList.add('status-critical');\n                else if (alertLevel === 'warning') el.classList.add('status-warning');\n                else el.classList.add('status-normal');\n            });\n            \n            const timeSpan = container.querySelector('.last-time');\n            if (timeSpan) timeSpan.innerHTML = new Date().toLocaleTimeString();\n        }\n\n        // Ajouter un patient\n        function addPatient() {\n            const contentNodeCode = getContentNodeCode();\n            if (!contentNodeCode) {\n                alert(\"Entrez d'abord un Content Node Code\");\n                return;\n            }\n            \n            const name = document.getElementById('patientName').value;\n            let id = document.getElementById('patientId').value;\n            \n            if (!name) {\n                alert(\"Entrez un nom\");\n                return;\n            }\n            if (!id) {\n                id = `patient_${Date.now()}`;\n            }\n            \n            if (patients[id]) {\n                alert(\"Ce patient existe déjà\");\n                return;\n            }\n            \n            patients[id] = {\n                name: name,\n                lastData: null,\n                interval: null,\n                uuid: null\n            };\n            \n            renderPatients();\n            \n            // Démarrer l'envoi pour ce patient\n            patients[id].interval = setInterval(() => {\n                sendHealthData(id);\n            }, 3000);\n            \n            document.getElementById('patientName').value = '';\n            document.getElementById('patientId').value = '';\n            \n            addLog(`✅ Patient ajouté: ${name} (${id})`);\n        }\n\n        // Supprimer un patient\n        function removePatient(patientId) {\n            if (patients[patientId].interval) {\n                clearInterval(patients[patientId].interval);\n            }\n            delete patients[patientId];\n            renderPatients();\n            addLog(`❌ Patient supprimé: ${patientId}`);\n        }\n\n        // Basculer l'affichage du contenu patient\n        function togglePatient(patientId) {\n            const content = document.getElementById(`content-${patientId}`);\n            if (content) {\n                content.classList.toggle('active');\n            }\n        }\n\n        // Rendre tous les patients\n        function renderPatients() {\n            const container = document.getElementById('patientsContainer');\n            \n            if (Object.keys(patients).length === 0) {\n                container.innerHTML = '<p style=\"text-align: center; color: white;\">Aucun patient. Ajoutez-en un !</p>';\n                return;\n            }\n            \n            container.innerHTML = Object.entries(patients).map(([id, patient]) => `\n                <div class=\"patient-card\" id=\"patient-${id}\">\n                    <div class=\"patient-header\" onclick=\"togglePatient('${id}')\">\n                        <div>\n                            🏥 <strong>${patient.name}</strong> (${id})\n                            <span class=\"alert-badge alert-normal\">✅ NORMAL</span>\n                        </div>\n                        <span>▼</span>\n                    </div>\n                    <div class=\"patient-content\" id=\"content-${id}\">\n                        <div class=\"vital-grid\">\n                            <div class=\"vital-card\">\n                                <div class=\"vital-label\">❤️ Rythme cardiaque</div>\n                                <div class=\"vital-value heart-rate-value status-normal\">--</div>\n                                <div class=\"vital-unit\">bpm</div>\n                            </div>\n                            <div class=\"vital-card\">\n                                <div class=\"vital-label\">🩸 Tension artérielle</div>\n                                <div><span class=\"vital-value systolic-value status-normal\">--</span><span class=\"vital-unit\"> / </span><span class=\"vital-value diastolic-value status-normal\">--</span></div>\n                                <div class=\"vital-unit\">mmHg</div>\n                            </div>\n                            <div class=\"vital-card\">\n                                <div class=\"vital-label\">🌡️ Température</div>\n                                <div class=\"vital-value temperature-value status-normal\">--</div>\n                                <div class=\"vital-unit\">°C</div>\n                            </div>\n                            <div class=\"vital-card\">\n                                <div class=\"vital-label\">💨 SpO2</div>\n                                <div class=\"vital-value oxygen-value status-normal\">--</div>\n                                <div class=\"vital-unit\">%</div>\n                            </div>\n                        </div>\n                        <div class=\"button-group\">\n                            <button class=\"btn btn-danger\" onclick=\"removePatient('${id}')\">🗑 Supprimer</button>\n                        </div>\n                        <div class=\"last-time\" style=\"font-size: 11px; color: #999; margin-top: 10px;\">\n                            🕐 Dernière mise à jour: --\n                        </div>\n                    </div>\n                </div>\n            `).join('');\n        }\n\n        // Ajouter un message dans le log global\n        function addLog(message) {\n            const logDiv = document.getElementById('globalLog');\n            const timestamp = new Date().toLocaleTimeString();\n            logDiv.innerHTML += `<div>[${timestamp}] ${message}</div>`;\n            logDiv.scrollTop = logDiv.scrollHeight;\n            if (logDiv.children.length > 100) {\n                logDiv.removeChild(logDiv.children[0]);\n            }\n        }\n\n        // Nettoyage\n        window.onbeforeunload = () => {\n            Object.values(patients).forEach(p => {\n                if (p.interval) clearInterval(p.interval);\n            });\n        };\n        \n        // Ajouter un patient par défaut pour la démo\n        setTimeout(() => {\n            if (Object.keys(patients).length === 0) {\n                document.getElementById('patientName').value = \"Jean Dupont\";\n                document.getElementById('patientId').value = \"patient_001\";\n                addPatient();\n                \n                setTimeout(() => {\n                    document.getElementById('patientName').value = \"Marie Martin\";\n                    document.getElementById('patientId').value = \"patient_002\";\n                    addPatient();\n                }, 500);\n            }\n        }, 1000);\n    </script>",

        "code": "SCRIPT-1775422992777",
        "type": "SCRIPT",
        "description": "dashboard",
        "content": "   <script>\n        let charts = {};\n        let refreshInterval;\n\n        // Récupérer TOUTES les données d'un content node\n        async function fetchAllHealthData() {\n            const contentNodeCode = document.getElementById('contentNodeCode').value.trim();\n            if (!contentNodeCode) {\n                return [];SCRIPT-1775422992777\n            }\n            \n            try {\n                const response = await fetch(`/datas/contentCode/${contentNodeCode}`, {\n                    method: 'GET',\n                    headers: { 'Accept': 'application/json' }\n                });\n                \n                if (response.ok) {\n                    const allData = await response.json();\n                    return allData;\n                }\n                return [];\n            } catch (error) {\n                console.error('Erreur fetch:', error);\n                return [];\n            }\n        }\n\n        // Rafraîchir les données\n        async function refreshData() {\n            const allData = await fetchAllHealthData();\n            \n            if (allData.length === 0) {\n                document.getElementById('patientsGrid').innerHTML = '<div class=\"no-data\">Aucune donnée santé trouvée. Lancez le simulateur !</div>';\n                document.getElementById('totalPatients').innerHTML = '0';\n                document.getElementById('criticalCount').innerHTML = '0';\n                document.getElementById('warningCount').innerHTML = '0';\n                return;\n            }\n            \n            // Grouper par patient pour avoir la dernière mesure et l'historique\n            const patientsMap = {};\n            const historyMap = {};\n            \n            allData.forEach(data => {\n                try {\n                    const healthData = JSON.parse(data.value);\n                    const patientId = healthData.device_id;\n                    \n                    // Dernière mesure\n                    if (!patientsMap[patientId] || healthData.timestamp_ms > patientsMap[patientId].timestamp_ms) {\n                        patientsMap[patientId] = {\n                            ...healthData,\n                            key: data.key,\n                            id: data.id\n                        };\n                    }\n                    \n                    // Historique\n                    if (!historyMap[patientId]) historyMap[patientId] = [];\n                    historyMap[patientId].push({\n                        heart_rate: healthData.heart_rate,\n                        timestamp_ms: healthData.timestamp_ms,\n                        timestamp: healthData.timestamp\n                    });\n                } catch (e) {\n                    console.error('Erreur parsing:', e);\n                }\n            });\n            \n            // Trier l'historique et garder les 20 derniers\n            Object.keys(historyMap).forEach(pid => {\n                historyMap[pid].sort((a, b) => a.timestamp_ms - b.timestamp_ms);\n                historyMap[pid] = historyMap[pid].slice(-20);\n            });\n            \n            updateDashboard(Object.values(patientsMap), historyMap);\n            \n            const critical = Object.values(patientsMap).filter(p => p.alert_level === 'critical').length;\n            const warning = Object.values(patientsMap).filter(p => p.alert_level === 'warning').length;\n            \n            document.getElementById('totalPatients').innerHTML = Object.keys(patientsMap).length;\n            document.getElementById('criticalCount').innerHTML = critical;\n            document.getElementById('warningCount').innerHTML = warning;\n        }\n\n        // Mettre à jour le dashboard\n        function updateDashboard(patients, history) {\n            const container = document.getElementById('patientsGrid');\n            \n            if (patients.length === 0) {\n                container.innerHTML = '<div class=\"no-data\">Aucun patient. Lancez le simulateur !</div>';\n                return;\n            }\n            \n            container.innerHTML = patients.map(patient => `\n                <div class=\"patient-card\" id=\"card-${patient.device_id}\">\n                    <div class=\"patient-header\">\n                        <div>\n                            🏥 <strong>${patient.patient_name}</strong><br>\n                            <small>${patient.device_id}</small>\n                        </div>\n                        <div class=\"alert-badge alert-${patient.alert_level}\">\n                            ${patient.alert_level === 'critical' ? '🚨 CRITIQUE' : (patient.alert_level === 'warning' ? '⚠️ ATTENTION' : '✅ NORMAL')}\n                        </div>\n                    </div>\n                    <div class=\"patient-body\">\n                        <div class=\"vitals\">\n                            <div class=\"vital-item\">\n                                <div class=\"vital-label\">❤️ Rythme cardiaque</div>\n                                <div class=\"vital-value\" id=\"hr-${patient.device_id}\">${Math.round(patient.heart_rate)}</div>\n                                <div class=\"vital-unit\">bpm</div>\n                            </div>\n                            <div class=\"vital-item\">\n                                <div class=\"vital-label\">🩸 Tension</div>\n                                <div class=\"vital-value\" id=\"bp-${patient.device_id}\">${Math.round(patient.blood_pressure_systolic)}/${Math.round(patient.blood_pressure_diastolic)}</div>\n                                <div class=\"vital-unit\">mmHg</div>\n                            </div>\n                            <div class=\"vital-item\">\n                                <div class=\"vital-label\">🌡️ Température</div>\n                                <div class=\"vital-value\" id=\"temp-${patient.device_id}\">${patient.temperature.toFixed(1)}</div>\n                                <div class=\"vital-unit\">°C</div>\n                            </div>\n                            <div class=\"vital-item\">\n                                <div class=\"vital-label\">💨 SpO2</div>\n                                <div class=\"vital-value\" id=\"ox-${patient.device_id}\">${Math.round(patient.oxygen_saturation)}</div>\n                                <div class=\"vital-unit\">%</div>\n                            </div>\n                        </div>\n                        <div class=\"timestamp\">\n                            🕐 ${new Date(patient.timestamp).toLocaleString()}\n                        </div>\n                        <div class=\"chart-container\">\n                            <canvas id=\"chart-${patient.device_id}\"></canvas>\n                        </div>\n                    </div>\n                </div>\n            `).join('');\n            \n            // Créer les graphiques\n            patients.forEach(patient => {\n                const patientHistory = history[patient.device_id] || [];\n                createChart(patient.device_id, patientHistory);\n            });\n        }\n\n        // Créer un graphique d'historique\n        function createChart(patientId, history) {\n            const canvas = document.getElementById(`chart-${patientId}`);\n            if (!canvas) return;\n            \n            const ctx = canvas.getContext('2d');\n            const labels = history.map(h => new Date(h.timestamp_ms).toLocaleTimeString());\n            const heartRates = history.map(h => h.heart_rate);\n            \n            if (charts[patientId]) {\n                charts[patientId].destroy();\n            }\n            \n            charts[patientId] = new Chart(ctx, {\n                type: 'line',\n                data: {\n                    labels: labels,\n                    datasets: [{\n                        label: 'Rythme cardiaque (bpm)',\n                        data: heartRates,\n                        borderColor: '#f44336',\n                        backgroundColor: 'rgba(244, 67, 54, 0.1)',\n                        tension: 0.3,\n                        fill: true,\n                        pointRadius: 2,\n                        pointHoverRadius: 5\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: true,\n                    plugins: {\n                        legend: { position: 'top', labels: { font: { size: 9 } } }\n                    },\n                    scales: {\n                        y: { min: 40, max: 140, title: { display: true, text: 'bpm', font: { size: 9 } } },\n                        x: { ticks: { font: { size: 8 } } }\n                    }\n                }\n            });\n        }\n\n        // Démarrer l'auto-refresh\n        function startAutoRefresh() {\n            refreshData();\n            refreshInterval = setInterval(refreshData, 5000);\n        }\n\n        // Écouter les changements de contentNodeCode\n        function setupContentCodeListener() {\n            const input = document.getElementById('contentNodeCode');\n            if (input) {\n                input.addEventListener('change', () => {\n                    refreshData();\n                });\n            }\n        }\n\n        // Initialisation\n        window.onload = () => {\n            setupContentCodeListener();\n            startAutoRefresh();\n        };\n\n        window.onbeforeunload = () => {\n            if (refreshInterval) clearInterval(refreshInterval);\n        };\n    </script>",

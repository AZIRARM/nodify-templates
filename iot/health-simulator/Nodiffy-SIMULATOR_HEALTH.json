        "content": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>🏥 Dashboard Santé IoT - Monitoring Patient</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n\t$content(STYLE-1775422973543)\n</head>\n<body>\n    <div class=\"header\">\n        <div>\n            <h1>🏥 Monitoring Patient IoT</h1>\n            <p>Nodify - Surveillance médicale temps réel</p>\n        </div>\n        <div class=\"stats-bar\">\n            <div class=\"control-group\">\n                <label>📦 Content Node Code:</label>\n                <input type=\"text\" id=\"contentNodeCode\" placeholder=\"health-data\" value=\"health-data\">\n            </div>\n            <div class=\"stat\">\n                <div class=\"stat-value\" id=\"totalPatients\">0</div>\n                <div class=\"stat-label\">Patients</div>\n            </div>\n            <div class=\"stat\">\n                <div class=\"stat-value\" id=\"criticalCount\">0</div>\n                <div class=\"stat-label\">Critiques</div>\n            </div>\n            <div class=\"stat\">\n                <div class=\"stat-value\" id=\"warningCount\">0</div>\n                <div class=\"stat-label\">Attention</div>\n            </div>\n            <button class=\"refresh-btn\" onclick=\"refreshData()\">🔄 Actualiser</button>\n            <span class=\"live-badge\">● LIVE</span>\n        </div>\n    </div>\n    \n    <div class=\"container\">\n        <div class=\"patients-grid\" id=\"patientsGrid\">\n            <div class=\"no-data\">Chargement des données patients...</div>\n        </div>\n    </div>\n\n \t$content(SCRIPT-1775422992777)\n</body>\n</html>",
